# Gemini API Key
# Lấy tại: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

GG_SHEET_ID=your_gg_sheet_id

# Firebase Web Config (cho frontend auth)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin (cho backend verify token)
FIREBASE_SERVICE_ACCOUNT_PATH=credentials/firebase-service-account.json
# Hoặc dùng JSON inline (ưu tiên cho deploy cloud)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Service Account cho Sheets (không cần file credentials.json khi deploy)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}